# Google Search Console
GSC_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  # JSON文字列をそのまま貼る
GSC_SITE_URL=https://greensnap.co.jp/

# PostgreSQL (Railwayが自動設定)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# 設定
TARGET_URL_PREFIX=https://greensnap.co.jp/columns/
ALERT_RANK_DROP_THRESHOLD=3       # 何位以上下落でアラート
ALERT_IMPRESSION_DROP_RATE=0.30   # 表示回数何%減でアラート
TOP_N_ARTICLES=100                # 監視対象記事数（表示回数Top N）
CRON_SCHEDULE=0 9 * * 1           # 毎週月曜9時（UTC+9考慮は Railway 側で設定）
